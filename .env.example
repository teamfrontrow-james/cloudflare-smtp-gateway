# ─────────────────────────────────────────────────────────────────────────────
# cloudflare-smtp-gateway configuration
#
# Every value here can ALSO be set later in the admin web UI (it persists to
# ./data/config.json). Env vars seed the defaults and override the saved file,
# so in containers/CI you can run fully headless from this file alone.
# Copy to ".env" and fill in. Never commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Cloudflare Email Service (required to actually send) ─────────────────────
# Create a scoped API token with the "Send Email" permission.
# (Onboard your sending domain first in the Cloudflare dashboard:
#  Email Service -> Email Sending -> Onboard Domain. That adds the SPF/DKIM/DMARC
#  + bounce records — it's dashboard-only, no API token permission needed for it.)
CF_API_TOKEN=
CF_ACCOUNT_ID=

# Comma-separated list of domains/addresses the gateway is allowed to send FROM.
# This MUST be a domain you have verified in Cloudflare Email Service.
# A bare domain (example.com) allows any address at that domain; a full address
# pins to exactly that sender. Anything else is rejected (anti-spoofing).
ALLOWED_FROM=example.com

# ── Authentication for the people/apps sending THROUGH the gateway ───────────
# SMTP login(s). Format: "user:password", comma-separated for multiple.
# Use long random passwords. This is what you put in WP Mail SMTP.
SMTP_USERS=wordpress:CHANGE_ME_long_random_secret

# Bearer token for the HTTP POST /send endpoint. Leave blank to disable HTTP send.
HTTP_TOKEN=

# Password for the admin web UI. If blank, the admin UI is DISABLED.
ADMIN_PASSWORD=

# ── Network / ports ──────────────────────────────────────────────────────────
SMTP_PORT=2525
HTTP_PORT=3000
# Interface to bind to. 127.0.0.1 keeps everything private to the host (best for
# a localhost sidecar). Use 0.0.0.0 to accept connections from other containers
# or the network (then make sure AUTH + tokens + a firewall are in place).
BIND_HOST=127.0.0.1
# Bind the admin UI to localhost only even when BIND_HOST is 0.0.0.0 (recommended).
ADMIN_LOCALHOST_ONLY=true

# ── Optional TLS for the SMTP listener (STARTTLS / implicit) ─────────────────
# Provide paths to a cert + key to enable TLS. Without these, STARTTLS is
# offered with a self-signed cert (fine for localhost; use real certs if exposed).
TLS_CERT_PATH=
TLS_KEY_PATH=

# ── Lockdown knobs (all optional) ────────────────────────────────────────────
# Per-credential/IP rate limits.
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=1000
# Comma-separated recipient rules. ALLOW wins if both set; otherwise DENY blocks.
# Accepts full addresses or "@domain.com". Empty = allow all recipients.
RECIPIENT_ALLOWLIST=
RECIPIENT_DENYLIST=
# CORS: comma-separated origins allowed to call POST /send from a browser. Empty = none.
ALLOWED_ORIGINS=
# Optional Cloudflare Turnstile secret to require a token on HTTP /send (for public forms).
TURNSTILE_SECRET=

# ── Misc ─────────────────────────────────────────────────────────────────────
# pino log level: trace|debug|info|warn|error
LOG_LEVEL=info
# Where GUI-saved config + the send log live.
DATA_DIR=./data
