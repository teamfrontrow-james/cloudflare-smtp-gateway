{
  "name": "cloudflare-smtp-gateway",
  "version": "0.1.0",
  "description": "Self-hostable SMTP + HTTP sending gateway for Cloudflare Email Service. Point WordPress (or any app) at it and send transactional mail through Cloudflare.",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "cloudflare-smtp-gateway": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "src/admin/ui",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "cloudflare",
    "email",
    "smtp",
    "smtp-relay",
    "smtp-gateway",
    "transactional-email",
    "wordpress",
    "wp-mail-smtp",
    "cloudflare-email-service",
    "mail-proxy"
  ],
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^8.1.1",
    "fastify": "^5.2.1",
    "mailparser": "^3.7.2",
    "pino": "^9.6.0",
    "smtp-server": "^3.13.6"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.5",
    "@eslint/js": "^9.20.0",
    "@types/node": "^22.13.1",
    "@types/smtp-server": "^3.5.10",
    "eslint": "^9.20.1",
    "typescript-eslint": "^8.24.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
